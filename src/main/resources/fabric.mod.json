{
  "schemaVersion": 1,
  "id": "tiered",
  "version": "${version}",
  "name": "Tiered",
  "description": "Adds tiers and attributes to equipments.",
  "authors": [
    "RafaPierangeli"
  ],
  "contact": {
    "issues": "",
    "homepage": ""
  },
  "license": "MIT",
  "icon": "assets/tiered/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "draylar.tiered.Tiered"
    ],
    "client": [
      "draylar.tiered.TieredClient"
    ],
    "modmenu": [
      "draylar.tiered.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "tiered.mixins.json",
    {
      "config": "tiered.mixins.client.json",
      "environment": "client"
    }
  ],
  "depends": {
    "java": ">=25",
    "minecraft": ">=26.1 <26.2",
    "fabric-api": ">=${fabric_version}",
    "fabricloader": ">=${loader_version}",
    "cloth-config2": ">=${cloth_config_version}"

  },
  "custom": {
    "mc-publish": {
      "modrinth": "H1dtyrlU",
      "curseforge": 1478973
    }
  }
}